<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - stranky_skoly</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/stranky_skoly.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="container header-flex">
            <img src="~/obrazky/logo_web.png" alt="logo sps Trutnov" class="logo" />

            <nav>
                <ul class="menu">
                    <li><a asp-controller="Home" asp-action="Index">Úvod</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <p>© 2026 Restaurace U Arouše</p>
            <p>
                <a href="#">Instagram</a> |
                <a href="#">Facebook</a>
            </p>
        </div>
    </footer>

</body>
</html>

